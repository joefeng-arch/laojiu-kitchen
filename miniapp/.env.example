# ─────────────────────────────────────────────────────────────
# 老舅厨房 微信小程序 环境变量模板
# 复制为 .env.development（开发）或 .env.production（发布）
# ─────────────────────────────────────────────────────────────

# ── 开发环境：电脑局域网 IP（真机调试用） ─────────────────
VITE_LAN_IP=192.168.x.x

# ── 生产环境：H5 部署后的 HTTPS 域名 ─────────────────────
# 同时需在微信公众平台「开发设置 → 业务域名」添加此域名
VITE_H5_BASE_URL=https://your-domain.com
