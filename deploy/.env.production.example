# ─────────────────────────────────────────────────────────────
# 老舅厨房 生产环境变量模板
# 复制此文件为 .env.production，填入真实值
# 部署脚本会将其复制到 server/.env.production 供 Docker 加载
# ─────────────────────────────────────────────────────────────

# ── 数据库（容器内主机名为 postgres）────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ujk_prod
DB_USER=ujk_user
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ── Redis（容器内主机名为 redis）────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT（用户端 / 管理端，各 64 随机 hex）────────────────────
# 生成: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_HEX
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=CHANGE_ME_ANOTHER_64_HEX
ADMIN_JWT_EXPIRES_IN=12h

# ── 微信小程序 ──────────────────────────────────────────────
WX_APPID=wxe657793473769f5a
WX_SECRET=CHANGE_ME_WX_SECRET
ALLOW_MOCK_LOGIN=false

# ── 文件上传 ─────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=5242880

# ── 服务器 ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── AI 智能导入（阿里百炼 DashScope） ───────────────────────
AI_PROVIDER=alibaba
AI_API_KEY=CHANGE_ME_DASHSCOPE_KEY
AI_MODEL=qwen-plus

# ── Seed（首次部署后请立刻改密）─────────────────────────────
ADMIN_SEED_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
